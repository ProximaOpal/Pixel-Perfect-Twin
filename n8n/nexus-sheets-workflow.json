    {
      "parameters": {
        "jsCode": "// Slim each lead to ONLY the fields the frontend needs.\nconst wanted = [\n  [\"Enquiry Date\", \"enquiryDate\"],\n  [\"Name\", \"name\"],\n  [\"Main Contact - Job Role\", \"jobRole\"],\n  [\"Company Name\", \"companyName\"],\n  [\"Company Sector\", \"companySector\"],\n  [\"Main Contact - Email\", \"email\"],\n  [\"Main Contact - Number\", \"phone\"],\n  [\"Client Reference Number\", \"referenceNumber\"],\n  [\"Source\", \"source\"],\n  [\"Best time to call\", \"bestTimeToCall\"],\n  [\"Market\", \"market\"],\n  [\"Event Type\", \"eventType\"],\n  [\"Year of Event\", \"yearOfEvent\"],\n  [\"Full Event Date\", \"fullEventDate\"],\n  [\"Event Date - Flexible?\", \"eventDateFlexible\"],\n  [\"Requested Event Times\", \"requestedEventTimes\"],\n  [\"Group Size\", \"groupSize\"],\n  [\"Budget\", \"budget\"],\n  [\"How did they hear about us?\", \"howHeard\"],\n  [\"Live/Dead\", \"status\"],\n];\n\nfunction norm(s) {\n  return String(s).replace(/\\s+/g, \" \").trim().toLowerCase();\n}\n\nfunction pick(row, prefix) {\n  const target = norm(prefix);\n  for (const key of Object.keys(row)) {\n    if (norm(key).startsWith(target)) return row[key];\n  }\n  return \"\";\n}\n\nconst leads = $input.all().map(item => {\n  const row = item.json;\n  const out = {};\n  for (const [prefix, alias] of wanted) {\n    out[alias] = pick(row, prefix);\n  }\n  return out;\n}).reverse();\n\nreturn [{ json: { count: leads.length, leads } }];"
      },
