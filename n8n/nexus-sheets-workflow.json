    {
      "parameters": {
        "jsCode": "// Normalize LeadUpdate payload for Google Sheets write.\n// mode=demo → Nexus Ops tab (append/update by ref/email)\n// mode=live → Enquiry - Lead Data (2026)\nconst body = $input.first().json;\nconst mode = body.mode === 'live' ? 'live' : 'demo';\nconst lookup = String(body.referenceNumber || body.email || '').trim();\n\nconst row = {\n  mode,\n  lookup,\n  referenceNumber: body.referenceNumber || '',\n  email: body.email || '',\n  leadName: body.leadName || '',\n  status: body.status || '',\n  assignedRep: body.assignedRep || '',\n  nextAction: body.nextAction || '',\n  packageAbbreviation: body.packageAbbreviation || '',\n  vivaTag: body.vivaTag === true || body.vivaTag === 'true' ? 'YES' : (body.vivaTag === false || body.vivaTag === 'false' ? 'NO' : ''),\n  quoteBuilt: body.quoteBuilt === true ? 'YES' : (body.quoteBuilt === false ? 'NO' : ''),\n  quoteApproved: body.quoteApproved === true ? 'YES' : (body.quoteApproved === false ? 'NO' : ''),\n  quoteVersion: body.quoteVersion || '',\n  updatedAt: new Date().toISOString(),\n};\n\nreturn [{ json: row }];"
      },
