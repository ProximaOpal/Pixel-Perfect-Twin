      "id": "4ee429c8-60ea-4eae-99bc-6ad3b604eb03",
      "name": "Get Leads",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [224, 240],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "8aF9CpidfdOSoB9E",
          "name": "Google Sheets OAuth2 API"
        }
      }
